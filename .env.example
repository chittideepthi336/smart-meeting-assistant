# Smart Meeting Assistant — Environment Variables
# ─────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit your .env to GitHub — it is already in .gitignore

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-very-long-random-secret-key-here

# ── Gemini AI (2.0 Flash) ─────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Firebase Firestore ────────────────────────────────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts → Generate key
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Download from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json

# Redirect URI — must match exactly what you configured in Google Cloud Console
# Development:  http://localhost:5000/auth/callback
# Production:   https://yourdomain.com/auth/callback
OAUTH_REDIRECT_URI=http://localhost:5000/auth/callback
